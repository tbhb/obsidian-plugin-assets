{
  "name": "obsidian-plugin-assets",
  "version": "0.1.0-beta.2",
  "description": "Verified fetch, cache, and resolve layer for Obsidian plugins that ship release-sourced assets.",
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "sigstore",
    "attestation",
    "github-release"
  ],
  "license": "MIT",
  "author": "Tony Burns <tony@tonyburns.net>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tbhb/obsidian-plugin-assets.git"
  },
  "bugs": {
    "url": "https://github.com/tbhb/obsidian-plugin-assets/issues"
  },
  "homepage": "https://github.com/tbhb/obsidian-plugin-assets#readme",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22.22.0 <23",
    "pnpm": ">=10"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "prepare": "husky",
    "dev": "vite build --watch",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "check": "biome check . && eslint .",
    "check:fix": "biome check --write . && eslint --fix .",
    "format": "biome format --write .",
    "format:markdown": "rumdl fmt .",
    "lint": "biome lint . && eslint .",
    "lint:actions": "actionlint",
    "lint:all": "pnpm run lint && pnpm run lint:markdown && pnpm run lint:yaml && pnpm run lint:spelling && pnpm run lint:actions && pnpm run lint:prose",
    "lint:markdown": "rumdl check .",
    "lint:markdown:fix": "rumdl check --fix .",
    "lint:prose": "vale --glob='!{.vale/**,node_modules/**,coverage/**,dist/**,CHANGELOG.md}' .",
    "lint:spelling": "cspell --no-progress --no-summary --gitignore .",
    "lint:staged": "nano-staged",
    "lint:yaml": "yamllint --strict .",
    "prepublishOnly": "pnpm run build",
    "vale:sync": "vale sync"
  },
  "nano-staged": {
    "*.{ts,mts,tsx,js,mjs,cjs,jsx,json,jsonc,css}": [
      "biome check --write --no-errors-on-unmatched --files-ignore-unknown=true"
    ],
    "src/**/*.{ts,mts,tsx}": [
      "eslint --fix --no-warn-ignored"
    ],
    "*.md": [
      "rumdl check --fix",
      "vale"
    ],
    "*.{yml,yaml}": "yamllint --strict",
    ".github/workflows/*.{yml,yaml}": "actionlint",
    "*.{ts,mts,tsx,js,mjs,cjs,jsx,json,jsonc,md,yml,yaml,css,html}": "cspell --no-progress --no-summary --no-must-find-files"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/node": "^22.19.0",
    "@vitest/coverage-v8": "^4.1.4",
    "cspell": "^9.7.0",
    "eslint": "^9.30.1",
    "globals": "^15.14.0",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "nano-staged": "^1.0.2",
    "tslib": "^2.8.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.1",
    "vite": "^8.0.8",
    "vite-plugin-dts": "^4.5.0",
    "vitest": "^4.1.4"
  }
}
